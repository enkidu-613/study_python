# ============================================
# LLM API 配置
# 复制此文件为 .env 并填入你的真实 API Key
# ============================================

# API 密钥（ModelScope / TokenHub / 百度千帆 等）
MODELSCOPE_API_KEY=your_api_key_here

# LLM 请求地址（OpenAI 兼容接口）
# 腾讯 TokenHub: https://tokenhub.tencentmaas.com/v1
# 百度千帆:     https://qianfan.baidubce.com/v2
# ModelScope:   https://api-inference.modelscope.cn/v1
MODEL_API_URL=https://qianfan.baidubce.com/v2

# LLM 模型名称
# 百度千帆: deepseek-v4-flash-202605
# ModelScope: deepseek-ai/DeepSeek-V3.2
MODEL_NAME=deepseek-v4-flash-202605

# ============================================
# Embedding 模型配置
# ============================================

#强制指定使用 MPS 设备
FORCE_DEVICE=mps
# 本地 Embedding 模型（HuggingFace 模型名）
# 推荐: BAAI/bge-small-zh-v1.5 (95MB, 512维, 本地部署)
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# Embedding 模型批量大小
# 推荐: 8 
EMBEDDING_BATCH_SIZE=8
